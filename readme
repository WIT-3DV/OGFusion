conda create -n OGFusion python=3.9 -y

conda activate OGFusion

pip install torch==1.13.0+cu117 torchvision==0.14.0+cu117 torchaudio==0.13.0+cu117 \
  --extra-index-url https://download.pytorch.org/whl/cu117

python -m pip install -e . --no-build-isolation

cd pcdet/ops/pillar_ops
python -m pip install -e . --no-build-isolation

python -m pip install -e detectron2

cd mask2former/modeling/pixel_decoder/ops
sh make.sh

python Mask2Former/demo/geometric_densification_vod.py   --pts-save-path ./data/view_of_delft_PUBLIC/vod_radar_5frames/training/mask2former_geometric_densification   --config-file Mask2Former/configs/cityscapes/instance-segmentation/swin/maskformer2_swin_large_IN21k_384_bs16_90k.yaml
python Mask2Former/demo/geometric_densification_tj4d.py   --pts-save-path ./data/kitti/training/mask2former_geometric_densification   --config-file Mask2Former/configs/cityscapes/instance-segmentation/swin/maskformer2_swin_large_IN21k_384_bs16_90k.yaml
